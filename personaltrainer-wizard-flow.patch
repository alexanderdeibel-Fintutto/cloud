diff --git a/api/create-checkout-session.ts b/api/create-checkout-session.ts
new file mode 100644
index 0000000..e6c257a
--- /dev/null
+++ b/api/create-checkout-session.ts
@@ -0,0 +1,70 @@
+import Stripe from 'stripe'
+import type { VercelRequest, VercelResponse } from '@vercel/node'
+
+const stripe = new Stripe(process.env.STRIPE_SECRET_KEY!, {
+  apiVersion: '2025-01-27.acacia' as Stripe.LatestApiVersion,
+})
+
+const TIER_PRICES: Record<string, { monthly: string; yearly: string }> = {
+  save_load: {
+    monthly: process.env.STRIPE_PRICE_SAVE_MONTHLY || '',
+    yearly: process.env.STRIPE_PRICE_SAVE_YEARLY || '',
+  },
+  basic: {
+    monthly: process.env.STRIPE_PRICE_BASIC_MONTHLY || '',
+    yearly: process.env.STRIPE_PRICE_BASIC_YEARLY || '',
+  },
+  premium: {
+    monthly: process.env.STRIPE_PRICE_PREMIUM_MONTHLY || '',
+    yearly: process.env.STRIPE_PRICE_PREMIUM_YEARLY || '',
+  },
+}
+
+export default async function handler(req: VercelRequest, res: VercelResponse) {
+  if (req.method !== 'POST') {
+    return res.status(405).json({ error: 'Method not allowed' })
+  }
+
+  try {
+    const { priceId, userId, userEmail, tierId, billing = 'monthly' } = req.body
+
+    // Use priceId from request or look up from tier config
+    let resolvedPriceId = priceId
+    if (!resolvedPriceId && tierId && TIER_PRICES[tierId]) {
+      resolvedPriceId = billing === 'yearly'
+        ? TIER_PRICES[tierId].yearly
+        : TIER_PRICES[tierId].monthly
+    }
+
+    if (!resolvedPriceId) {
+      return res.status(400).json({ error: 'No valid price found for this tier' })
+    }
+
+    const origin = req.headers.origin || req.headers.referer || 'https://personaltrainer.vercel.app'
+
+    const session = await stripe.checkout.sessions.create({
+      mode: 'subscription',
+      payment_method_types: ['card'],
+      line_items: [{ price: resolvedPriceId, quantity: 1 }],
+      success_url: `${origin}/checkout/success?session_id={CHECKOUT_SESSION_ID}`,
+      cancel_url: `${origin}/checkout/cancel`,
+      customer_email: userEmail || undefined,
+      metadata: {
+        userId: userId || '',
+        tierId: tierId || '',
+      },
+      subscription_data: {
+        metadata: {
+          userId: userId || '',
+          tierId: tierId || '',
+        },
+      },
+    })
+
+    return res.status(200).json({ url: session.url })
+  } catch (error: unknown) {
+    const message = error instanceof Error ? error.message : 'Unknown error'
+    console.error('[FitTutto] Checkout error:', message)
+    return res.status(500).json({ error: message })
+  }
+}
diff --git a/api/customer-portal.ts b/api/customer-portal.ts
new file mode 100644
index 0000000..ff0fed1
--- /dev/null
+++ b/api/customer-portal.ts
@@ -0,0 +1,33 @@
+import Stripe from 'stripe'
+import type { VercelRequest, VercelResponse } from '@vercel/node'
+
+const stripe = new Stripe(process.env.STRIPE_SECRET_KEY!, {
+  apiVersion: '2025-01-27.acacia' as Stripe.LatestApiVersion,
+})
+
+export default async function handler(req: VercelRequest, res: VercelResponse) {
+  if (req.method !== 'POST') {
+    return res.status(405).json({ error: 'Method not allowed' })
+  }
+
+  try {
+    const { customerId } = req.body
+
+    if (!customerId) {
+      return res.status(400).json({ error: 'Customer ID is required' })
+    }
+
+    const origin = req.headers.origin || req.headers.referer || 'https://personaltrainer.vercel.app'
+
+    const session = await stripe.billingPortal.sessions.create({
+      customer: customerId,
+      return_url: `${origin}/profile`,
+    })
+
+    return res.status(200).json({ url: session.url })
+  } catch (error: unknown) {
+    const message = error instanceof Error ? error.message : 'Unknown error'
+    console.error('[FitTutto] Portal error:', message)
+    return res.status(500).json({ error: message })
+  }
+}
diff --git a/api/stripe-webhook.ts b/api/stripe-webhook.ts
new file mode 100644
index 0000000..9832123
--- /dev/null
+++ b/api/stripe-webhook.ts
@@ -0,0 +1,154 @@
+import Stripe from 'stripe'
+import { createClient } from '@supabase/supabase-js'
+import type { VercelRequest, VercelResponse } from '@vercel/node'
+
+const stripe = new Stripe(process.env.STRIPE_SECRET_KEY!, {
+  apiVersion: '2025-01-27.acacia' as Stripe.LatestApiVersion,
+})
+
+const supabase = createClient(
+  process.env.SUPABASE_URL || process.env.VITE_SUPABASE_URL || '',
+  process.env.SUPABASE_SERVICE_ROLE_KEY || ''
+)
+
+const PRICE_TO_TIER: Record<string, string> = {}
+
+// Build price-to-tier mapping from environment variables
+function getPriceToTierMap(): Record<string, string> {
+  const map: Record<string, string> = {}
+  const tiers = ['save_load', 'basic', 'premium']
+  const periods = ['MONTHLY', 'YEARLY']
+
+  for (const tier of tiers) {
+    for (const period of periods) {
+      const envKey = `STRIPE_PRICE_${tier.toUpperCase()}_${period}`
+      const priceId = process.env[envKey]
+      if (priceId) map[priceId] = tier
+    }
+  }
+  return map
+}
+
+async function updateSubscriptionTier(userId: string, tier: string, stripeCustomerId?: string, stripeSubscriptionId?: string) {
+  const updateData: Record<string, unknown> = {
+    subscription_tier: tier,
+    updated_at: new Date().toISOString(),
+  }
+  if (stripeCustomerId) updateData.stripe_customer_id = stripeCustomerId
+  if (stripeSubscriptionId) updateData.stripe_subscription_id = stripeSubscriptionId
+
+  const { error } = await supabase
+    .from('fitness_profiles')
+    .update(updateData)
+    .eq('user_id', userId)
+
+  if (error) {
+    console.error('[FitTutto] Failed to update subscription tier:', error)
+    throw error
+  }
+  console.log(`[FitTutto] Updated user ${userId} to tier: ${tier}`)
+}
+
+export const config = {
+  api: { bodyParser: false },
+}
+
+async function getRawBody(req: VercelRequest): Promise<Buffer> {
+  const chunks: Buffer[] = []
+  return new Promise((resolve, reject) => {
+    req.on('data', (chunk: Buffer) => chunks.push(chunk))
+    req.on('end', () => resolve(Buffer.concat(chunks)))
+    req.on('error', reject)
+  })
+}
+
+export default async function handler(req: VercelRequest, res: VercelResponse) {
+  if (req.method !== 'POST') {
+    return res.status(405).json({ error: 'Method not allowed' })
+  }
+
+  const sig = req.headers['stripe-signature'] as string
+  const webhookSecret = process.env.STRIPE_WEBHOOK_SECRET
+
+  if (!sig || !webhookSecret) {
+    return res.status(400).json({ error: 'Missing signature or webhook secret' })
+  }
+
+  let event: Stripe.Event
+
+  try {
+    const rawBody = await getRawBody(req)
+    event = stripe.webhooks.constructEvent(rawBody, sig, webhookSecret)
+  } catch (err: unknown) {
+    const message = err instanceof Error ? err.message : 'Unknown error'
+    console.error('[FitTutto] Webhook signature verification failed:', message)
+    return res.status(400).json({ error: `Webhook Error: ${message}` })
+  }
+
+  const priceToTier = getPriceToTierMap()
+
+  try {
+    switch (event.type) {
+      case 'checkout.session.completed': {
+        const session = event.data.object as Stripe.Checkout.Session
+        const userId = session.metadata?.userId
+        const tierId = session.metadata?.tierId
+
+        if (userId && tierId) {
+          await updateSubscriptionTier(
+            userId,
+            tierId,
+            session.customer as string,
+            session.subscription as string
+          )
+        }
+        break
+      }
+
+      case 'customer.subscription.updated': {
+        const subscription = event.data.object as Stripe.Subscription
+        const userId = subscription.metadata?.userId
+
+        if (userId) {
+          // Determine tier from the price
+          const priceId = subscription.items.data[0]?.price?.id
+          const tier = priceToTier[priceId || ''] || subscription.metadata?.tierId
+
+          if (subscription.status === 'active' && tier) {
+            await updateSubscriptionTier(userId, tier)
+          } else if (subscription.status === 'past_due' || subscription.status === 'unpaid') {
+            // Keep current tier but could add warning
+            console.warn(`[FitTutto] Subscription ${subscription.id} is ${subscription.status}`)
+          }
+        }
+        break
+      }
+
+      case 'customer.subscription.deleted': {
+        const subscription = event.data.object as Stripe.Subscription
+        const userId = subscription.metadata?.userId
+
+        if (userId) {
+          await updateSubscriptionTier(userId, 'free')
+          console.log(`[FitTutto] Subscription cancelled for user ${userId}`)
+        }
+        break
+      }
+
+      case 'invoice.payment_failed': {
+        const invoice = event.data.object as Stripe.Invoice
+        console.warn(`[FitTutto] Payment failed for invoice ${invoice.id}`)
+        break
+      }
+
+      default:
+        console.log(`[FitTutto] Unhandled event type: ${event.type}`)
+    }
+
+    return res.status(200).json({ received: true })
+  } catch (error: unknown) {
+    const message = error instanceof Error ? error.message : 'Unknown error'
+    console.error('[FitTutto] Webhook handler error:', message)
+    return res.status(500).json({ error: message })
+  }
+}
