--- /dev/null
+++ b/scripts/setup-stripe.sh
@@ -0,0 +1,140 @@
+#!/bin/bash
+# FitTutto - Stripe Produkte & Preise anlegen
+# Usage: bash scripts/setup-stripe.sh sk_live_DEIN_KEY
+#
+# Erstellt 3 Produkte mit je 2 Preisen (monatlich + jährlich)
+# und gibt die Price-IDs aus, die in Vercel Env-Vars eingetragen werden müssen.
+
+set -e
+
+STRIPE_KEY="${1}"
+
+if [ -z "$STRIPE_KEY" ]; then
+  echo "Usage: bash scripts/setup-stripe.sh sk_live_DEIN_STRIPE_SECRET_KEY"
+  exit 1
+fi
+
+API="https://api.stripe.com/v1"
+AUTH="Bearer $STRIPE_KEY"
+
+echo "============================================"
+echo "  FitTutto - Stripe Setup"
+echo "============================================"
+echo ""
+
+# --- Produkt 1: Speichern & Laden (2,99€/mo, 28,70€/yr) ---
+echo ">> Erstelle Produkt: FitTutto Speichern & Laden..."
+PROD1=$(curl -s -X POST "$API/products" \
+  -H "Authorization: $AUTH" \
+  -d "name=FitTutto Speichern & Laden" \
+  -d "description=Trainingsplan speichern & laden, mehrere Pläne verwalten, Trainingshistorie (30 Tage), werbefrei." \
+  -d "metadata[tier]=save_load" \
+  | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])")
+echo "   Produkt: $PROD1"
+
+PRICE_SAVE_MONTHLY=$(curl -s -X POST "$API/prices" \
+  -H "Authorization: $AUTH" \
+  -d "product=$PROD1" \
+  -d "unit_amount=299" \
+  -d "currency=eur" \
+  -d "recurring[interval]=month" \
+  -d "metadata[tier]=save_load" \
+  -d "metadata[period]=monthly" \
+  | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])")
+echo "   Monatlich: $PRICE_SAVE_MONTHLY"
+
+PRICE_SAVE_YEARLY=$(curl -s -X POST "$API/prices" \
+  -H "Authorization: $AUTH" \
+  -d "product=$PROD1" \
+  -d "unit_amount=2870" \
+  -d "currency=eur" \
+  -d "recurring[interval]=year" \
+  -d "metadata[tier]=save_load" \
+  -d "metadata[period]=yearly" \
+  | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])")
+echo "   Jährlich:  $PRICE_SAVE_YEARLY"
+echo ""
+
+# --- Produkt 2: Basic (4,99€/mo, 47,90€/yr) ---
+echo ">> Erstelle Produkt: FitTutto Basic..."
+PROD2=$(curl -s -X POST "$API/products" \
+  -H "Authorization: $AUTH" \
+  -d "name=FitTutto Basic" \
+  -d "description=Ernährungstracking, Makro-Tracking, Fortschrittsstatistiken, Streaks, persönliche Rekorde, KI-Trainingsanpassungen." \
+  -d "metadata[tier]=basic" \
+  | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])")
+echo "   Produkt: $PROD2"
+
+PRICE_BASIC_MONTHLY=$(curl -s -X POST "$API/prices" \
+  -H "Authorization: $AUTH" \
+  -d "product=$PROD2" \
+  -d "unit_amount=499" \
+  -d "currency=eur" \
+  -d "recurring[interval]=month" \
+  -d "metadata[tier]=basic" \
+  -d "metadata[period]=monthly" \
+  | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])")
+echo "   Monatlich: $PRICE_BASIC_MONTHLY"
+
+PRICE_BASIC_YEARLY=$(curl -s -X POST "$API/prices" \
+  -H "Authorization: $AUTH" \
+  -d "product=$PROD2" \
+  -d "unit_amount=4790" \
+  -d "currency=eur" \
+  -d "recurring[interval]=year" \
+  -d "metadata[tier]=basic" \
+  -d "metadata[period]=yearly" \
+  | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])")
+echo "   Jährlich:  $PRICE_BASIC_YEARLY"
+echo ""
+
+# --- Produkt 3: Premium (9,99€/mo, 95,90€/yr) ---
+echo ">> Erstelle Produkt: FitTutto Premium..."
+PROD3=$(curl -s -X POST "$API/products" \
+  -H "Authorization: $AUTH" \
+  -d "name=FitTutto Premium" \
+  -d "description=Alle Features: Mobility, KI-Ernährungsberater, Mahlzeitenpläne, Barcode-Scanner, Körperanalyse, Community." \
+  -d "metadata[tier]=premium" \
+  | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])")
+echo "   Produkt: $PROD3"
+
+PRICE_PREMIUM_MONTHLY=$(curl -s -X POST "$API/prices" \
+  -H "Authorization: $AUTH" \
+  -d "product=$PROD3" \
+  -d "unit_amount=999" \
+  -d "currency=eur" \
+  -d "recurring[interval]=month" \
+  -d "metadata[tier]=premium" \
+  -d "metadata[period]=monthly" \
+  | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])")
+echo "   Monatlich: $PRICE_PREMIUM_MONTHLY"
+
+PRICE_PREMIUM_YEARLY=$(curl -s -X POST "$API/prices" \
+  -H "Authorization: $AUTH" \
+  -d "product=$PROD3" \
+  -d "unit_amount=9590" \
+  -d "currency=eur" \
+  -d "recurring[interval]=year" \
+  -d "metadata[tier]=premium" \
+  -d "metadata[period]=yearly" \
+  | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])")
+echo "   Jährlich:  $PRICE_PREMIUM_YEARLY"
+echo ""
+
+echo "============================================"
+echo "  FERTIG! Trage diese in Vercel ein:"
+echo "============================================"
+echo ""
+echo "STRIPE_PRICE_SAVE_LOAD_MONTHLY=$PRICE_SAVE_MONTHLY"
+echo "STRIPE_PRICE_SAVE_LOAD_YEARLY=$PRICE_SAVE_YEARLY"
+echo "STRIPE_PRICE_BASIC_MONTHLY=$PRICE_BASIC_MONTHLY"
