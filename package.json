{
  "name": "fintutto-portal-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:portal": "npm run dev --workspace=apps/fintutto-portal",
    "dev:vermieter": "npm run dev --workspace=apps/vermieter-portal",
    "dev:vermietify": "npm run dev --workspace=apps/vermietify",
    "build": "vite build",
    "build:portal": "npm run build --workspace=apps/fintutto-portal",
    "build:vermieter": "npm run build --workspace=apps/vermieter-portal",
    "build:vermietify": "npm run build --workspace=apps/vermietify",
    "dev:translator": "npm run dev --workspace=apps/translator",
    "build:translator": "npm run build --workspace=apps/translator",
    "dev:secondbrain": "npm run dev --workspace=apps/secondbrain",
    "build:secondbrain": "npm run build --workspace=apps/secondbrain",
    "build:all": "npm run build && npm run build:portal && npm run build:vermieter && npm run build:vermietify && npm run build:secondbrain",
    "dev:pflanzen": "npm run dev --workspace=apps/pflanzen-manager",
    "build:pflanzen": "npm run build --workspace=apps/pflanzen-manager",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fintutto/shared": "*",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@supabase/supabase-js": "^2.43.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.358.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "sonner": "^1.4.3",
    "stripe": "^14.0.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.6"
  }
}
