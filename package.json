{
  "name": "fintutto-portal-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.29.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:compass": "pnpm --filter @fintutto/app-financial-compass dev",
    "dev:vermietify": "pnpm --filter @fintutto/app-vermietify dev",
    "dev:portal": "pnpm --filter @fintutto/app-fintutto-portal dev",
    "dev:all": "concurrently \"pnpm dev:compass\" \"pnpm dev:vermietify\"",
    "build:compass": "pnpm --filter @fintutto/app-financial-compass build",
    "build:vermietify": "pnpm --filter @fintutto/app-vermietify build",
    "build:portal": "pnpm --filter @fintutto/app-fintutto-portal build",
    "build:all": "pnpm build:compass && pnpm build:vermietify",
    "build:turbo": "turbo run build",
    "lint": "pnpm -r lint",
    "preview": "vite preview",
    "test": "pnpm exec vitest run src/__tests__/regression/",
    "test:watch": "pnpm exec vitest src/__tests__/regression/",
    "test:ci": "pnpm exec vitest run src/__tests__/regression/ --reporter=verbose"
  },
  "dependencies": {
    "@fintutto/shared": "workspace:*",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@supabase/supabase-js": "^2.104.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "turbo": "^2.3.3",
    "vitest": "^4.1.5"
  }
}
