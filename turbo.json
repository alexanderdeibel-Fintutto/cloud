{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "public/**", "index.html", "vite.config.*", "tsconfig*.json", "package.json"],
      "outputs": ["dist/**", ".vite/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "*.ts", "*.tsx", ".eslintrc*", "eslint.config.*"]
    },
    "test": {
      "inputs": ["src/**", "*.test.ts", "*.test.tsx", "vitest.config.*"],
      "outputs": ["coverage/**"]
    },
    "test:ci": {
      "inputs": ["src/**", "*.test.ts", "*.test.tsx", "vitest.config.*"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig*.json"]
    }
  }
}
