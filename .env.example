# ===================================
# Fintutto Ecosystem - Umgebungsvariablen
# ===================================

# Datenbank
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fintutto"

# JWT Secret (in Produktion durch sicheren Wert ersetzen!)
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# API Server
PORT=3001
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# S3 / Object Storage
S3_REGION=eu-central-1
S3_BUCKET=fintutto-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=  # Optional: Für MinIO oder andere S3-kompatible Dienste
S3_PUBLIC_URL=https://storage.fintutto.cloud

# E-Mail (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fintutto.cloud

# Anthropic API (für KI-Features)
ANTHROPIC_API_KEY=

# Optional: Stripe (für Abonnements)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: Sentry (für Error Tracking)
SENTRY_DSN=
