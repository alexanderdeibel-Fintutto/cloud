{
  "framework": "vite",
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- . ../../packages/shared/src/ || exit 1",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter @fintutto/financial-compass build",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
