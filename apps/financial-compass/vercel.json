{
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "dist",
  "framework": "vite",
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- apps/financial-compass/ || exit 1",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
