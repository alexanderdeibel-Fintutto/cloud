<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Microphone Permission -->
    <key>NSMicrophoneUsageDescription</key>
    <string>AI-Guide needs microphone access to record your speech for live translation during guided tours.</string>

    <!-- Speech Recognition Permission -->
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>AI-Guide uses on-device speech recognition to transcribe your speech for translation.</string>

    <!-- Camera Permission (QR Code Scanner) -->
    <key>NSCameraUsageDescription</key>
    <string>AI-Guide uses the camera to scan QR codes for joining guide sessions.</string>

    <!-- Local Network Permission (WebSocket Server + Bonjour) -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>AI-Guide uses the local network to connect guides with listeners for real-time translation.</string>

    <!-- Bonjour Services -->
    <key>NSBonjourServices</key>
    <array>
        <string>_aiguide-tour._tcp</string>
    </array>

    <!-- Multipeer Connectivity -->
    <key>NSNearbyInteractionAllowOnceUsageDescription</key>
    <string>AI-Guide uses nearby interaction to automatically discover guide sessions.</string>

    <!-- Background Modes -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>

    <!-- App Transport Security (local network) -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
</dict>
</plist>
