{
  "name": "widerspruch-jobcenter",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm dev:server\"",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "bot:generate-personas": "tsx server/cli.ts generate-personas",
    "bot:generate-schedule": "tsx server/cli.ts generate-schedule",
    "bot:setup-wp": "tsx server/cli.ts setup-wp-users",
    "bot:start": "tsx server/cli.ts start-bot",
    "bot:status": "tsx server/cli.ts status",
    "bot:test-wp": "tsx server/cli.ts test-wp",
    "bot:discover-wp": "tsx server/cli.ts discover-wp",
    "bot:setup-categories": "tsx server/cli.ts setup-wp-categories",
    "bot:setup-forums": "tsx server/cli.ts setup-wp-forums",
    "server": "tsx server/index.ts",
    "server:pm2": "npx pm2 start ecosystem.config.cjs",
    "server:pm2:stop": "npx pm2 stop board-bot",
    "server:pm2:logs": "npx pm2 logs board-bot",
    "server:pm2:status": "npx pm2 status"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "lucide-react": "^0.323.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.22.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.16",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.1",
    "typescript": "^6.0.3",
    "vite": "^5.1.0"
  }
}
