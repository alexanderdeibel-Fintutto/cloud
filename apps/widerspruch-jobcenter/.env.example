# ══════════════════════════════════════════════════════════════
# widerspruchjobcenter.de – Board-Bot Konfiguration
# ══════════════════════════════════════════════════════════════

# WordPress-Instanz
WP_BASE_URL=https://buergergeld-blog.de
WP_REST_URL=https://buergergeld-blog.de/wp-json

# Admin-API-Zugang (Application Password)
WP_ADMIN_USER=bgblog-bot
WP_ADMIN_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── bbPress Forum IDs (nach Einrichtung eintragen) ──
FORUM_ID_HILFE_BESCHEID=0
FORUM_ID_WIDERSPRUCH=0
FORUM_ID_SANKTIONEN=0
FORUM_ID_KDU_MIETE=0
FORUM_ID_ZUVERDIENST=0
FORUM_ID_ERFOLGE=0
FORUM_ID_AUSKOTZEN=0
FORUM_ID_ALLGEMEINES=0

# ── Blog-Kategorie IDs (nach Einrichtung eintragen) ──
CAT_AKTUELLES=0
CAT_WIDERSPRUCH=0
CAT_MEHRBEDARF=0
CAT_SANKTIONEN=0
CAT_KDU_MIETE=0
CAT_EINKOMMEN=0
CAT_RECHTE_TIPPS=0
CAT_ERFAHRUNGEN=0

# ── Bot-Einstellungen ──
BOT_MIN_DELAY_MINUTES=15
BOT_MAX_DELAY_MINUTES=180
BOT_MAX_POSTS_PER_DAY=8
BOT_MAX_COMMENTS_PER_DAY=15
BOT_ACTIVE_HOURS_START=7
BOT_ACTIVE_HOURS_END=23

# ── BescheidBoxer Mention Rate (0.0 - 1.0) ──
BESCHEIDBOXER_MENTION_RATE=0.18

# ── Server ──
SERVER_PORT=3001
