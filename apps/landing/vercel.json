{
  "framework": "vite",
  "installCommand": "pnpm install",
  "buildCommand": "cd ../.. && pnpm install && pnpm --filter @fintutto/cloud-landing build",
  "outputDirectory": "dist",
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- apps/landing/ packages/ || exit 1",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
