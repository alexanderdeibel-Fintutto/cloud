{
  "files": [],
  "references": [{ "path": "./tsconfig.app.json" }, { "path": "./tsconfig.node.json" }],
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@fintutto/shared": ["../../packages/shared/src/index.ts"],
      "@fintutto/banking": ["../../packages/shared/src/hooks/useBanking.ts"],
      "@fintutto/documents": ["../../packages/shared/src/components/documents/index.ts"]
    },
    "noImplicitAny": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "allowJs": true,
    "noUnusedLocals": false,
    "strictNullChecks": false
  }
}
