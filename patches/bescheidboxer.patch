+// Referral-System fuer BescheidBoxer
+// Belohnung: 30 Bonus-Credits fuer BEIDE Seiten
+
+import { useState, useEffect, useCallback } from 'react'
+import { supabase } from '@/integrations/supabase/client'
+import { useToast } from '@/hooks/use-toast'
+
+interface Referral {
+  id: string
+  referred_email: string
+  status: string
+  reward_applied_referrer: boolean
+  created_at: string
+  converted_at: string | null
+}
+
+interface ReferralStats {
+  total_sent: number
+  total_converted: number
+  total_credits_earned: number
+}
+
+export function useReferrals() {
+  const { toast } = useToast()
+  const [referralCode, setReferralCode] = useState<string | null>(null)
+  const [referrals, setReferrals] = useState<Referral[]>([])
+  const [stats, setStats] = useState<ReferralStats>({
+    total_sent: 0,
+    total_converted: 0,
+    total_credits_earned: 0,
+  })
+  const [loading, setLoading] = useState(true)
+
+  const generateCode = useCallback((userId: string) => {
+    const base = userId.replace(/-/g, '').substring(0, 8).toUpperCase()
+    return `BB-${base}`
+  }, [])
+
+  const ensureReferralCode = useCallback(async () => {
+    const { data: { user } } = await supabase.auth.getUser()
+    if (!user) return
+
+    const { data: profile } = await supabase
+      .from('amt_users')
+      .select('referral_code')
+      .eq('id', user.id)
+      .single()
+
+    if (profile?.referral_code) {
+      setReferralCode(profile.referral_code)
+    } else {
+      const code = generateCode(user.id)
+      await supabase
+        .from('amt_users')
+        .update({ referral_code: code })
+        .eq('id', user.id)
+      setReferralCode(code)
+    }
+  }, [generateCode])
+
+  const fetchReferrals = useCallback(async () => {
+    const { data: { user } } = await supabase.auth.getUser()
+    if (!user) return
+    setLoading(true)
+
+    try {
+      const { data, error } = await supabase
+        .from('amt_referrals')
+        .select('*')
+        .eq('referrer_user_id', user.id)
+        .order('created_at', { ascending: false })
+
+      if (error) throw error
+
+      const refs = (data || []) as Referral[]
+      setReferrals(refs)
+
+      const converted = refs.filter((r) => r.status === 'converted').length
+      const rewarded = refs.filter((r) => r.reward_applied_referrer).length
+
+      setStats({
+        total_sent: refs.length,
+        total_converted: converted,
+        total_credits_earned: rewarded * 30, // 30 Credits pro Referral
+      })
+    } catch (err) {
+      console.error('Error fetching referrals:', err)
+    } finally {
+      setLoading(false)
+    }
+  }, [])
+
+  useEffect(() => {
+    ensureReferralCode()
+    fetchReferrals()
+  }, [ensureReferralCode, fetchReferrals])
+
+  const createReferral = async (email: string) => {
+    const { data: { user } } = await supabase.auth.getUser()
+    if (!user || !referralCode) return false
+
+    try {
+      const { error } = await supabase.from('amt_referrals').insert({
+        referrer_user_id: user.id,
+        referred_email: email.toLowerCase(),
+        referral_code: `${referralCode}-${Date.now().toString(36)}`,
+        status: 'pending',
+      })
+
+      if (error) throw error
+
+      toast({
+        title: 'Einladung erstellt',
+        description: `Referral-Link fuer ${email} wurde generiert.`,
+      })
+
+      await fetchReferrals()
+      return true
+    } catch (err) {
+      console.error('Error creating referral:', err)
+      toast({
+        title: 'Fehler',
+        description: 'Referral konnte nicht erstellt werden.',
+        variant: 'destructive',
+      })
+      return false
+    }
+  }
+
+  const copyReferralLink = async () => {
+    if (!referralCode) return false
+    const link = `https://bescheidboxer.fintutto.cloud/registrieren?ref=${referralCode}`
+    await navigator.clipboard.writeText(link)
+    toast({
+      title: 'Link kopiert!',
+      description: 'Der Referral-Link wurde in die Zwischenablage kopiert.',
+    })
+    return true
+  }
+
+  return {
+    referralCode,
+    referrals,
+    stats,
+    loading,
+    createReferral,
+    copyReferralLink,
+    fetchReferrals,
+  }
+}
