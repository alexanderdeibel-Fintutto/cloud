+    if (error || !data?.signedUrl) {
+      toast({ title: "Fehler", description: "Anhang konnte nicht heruntergeladen werden", variant: "destructive" });
+      return;
+    }
+
+    const a = document.createElement("a");
+    a.href = data.signedUrl;
+    a.download = fileName;
+    a.click();
+  };
